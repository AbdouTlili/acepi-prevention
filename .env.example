# ─── LOCAL DEVELOPMENT (SQLite) ──────────────────────────────────────────────
DATABASE_URL="file:./data/acepi.db"
SESSION_SECRET="acepi-local-dev-secret-change-me-in-production"

# ─── GCP PRODUCTION (PostgreSQL via Cloud SQL) ───────────────────────────────
# Cloud Run connects to Cloud SQL via Unix socket — no public IP or firewall needed.
# Replace PROJECT_ID, REGION, INSTANCE_NAME with your actual values.
#
# DATABASE_URL="postgresql://acepi:YOUR_DB_PASSWORD@/acepi?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME"
# SESSION_SECRET="<openssl rand -hex 32>"
# RESET_SECRET="<set temporarily when you need emergency password reset>"
# DEFAULT_USERNAME=admin
# DEFAULT_PASSWORD=<strong password for first-run seed>

# ─── OPTIONAL ────────────────────────────────────────────────────────────────
APP_PIN=""
